# Required: LiveKit room used as the raw RTC audio router.
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_ROOM=vox-symposium

# Audio defaults. LiveKit publishes mono PCM at this rate; model adapters resample as needed.
LIVEKIT_PUBLISH_SAMPLE_RATE=48000
LIVEKIT_FRAME_MS=20

# Provider can be: openai, gemini, local, hf.
# `hf` is an alias for the local Hugging Face/self-hosted adapter.
AGENT_CITIZEN_IDENTITY=agent-citizen
AGENT_CITIZEN_PROVIDER=openai
AGENT_CITIZEN_INSTRUCTIONS=You are Agent-Citizen, representing a human user. Keep replies concise and conversational.

AGENT_SCHOLAR_IDENTITY=agent-scholar
AGENT_SCHOLAR_PROVIDER=local
AGENT_SCHOLAR_INSTRUCTIONS=You are Agent-Scholar, the voice agent under test. Keep replies concise and conversational.

# Required only when at least one agent uses provider=openai.
OPENAI_API_KEY=your_openai_api_key
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin

# Required only when at least one agent uses provider=gemini.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Local/HF model settings. Required only when at least one agent uses provider=local or provider=hf.
# auto infers from LOCAL_MODEL; supported explicit values: minicpmo, qwen3_omni.
LOCAL_MODEL_PROVIDER=auto

# MiniCPM-o example:
LOCAL_MODEL=openbmb/MiniCPM-o-4_5
# Qwen3-Omni audio-output example:
# LOCAL_MODEL=Qwen/Qwen3-Omni-30B-A3B-Instruct

# Device/dtype loading hints for local model backends.
# For Qwen3-Omni, LOCAL_MODEL_ATTN_IMPLEMENTATION=flash_attention_2 is commonly expected.
LOCAL_MODEL_DEVICE=auto
LOCAL_MODEL_DTYPE=auto
LOCAL_MODEL_ATTN_IMPLEMENTATION=sdpa

# Optional MiniCPM-o reference voice prompt. Use an absolute path to a wav file when voice cloning is needed.
LOCAL_MODEL_REF_AUDIO=
LOCAL_MODEL_LANGUAGE=en

# Prefer model-native end-of-turn if supported; otherwise fallback to Silero VAD.
# Set false to always use Silero VAD.
LOCAL_MODEL_TURN_DETECTION=true
LOCAL_MODEL_SILERO_THRESHOLD=0.5
LOCAL_MODEL_TURN_SILENCE_MS=700
LOCAL_MODEL_MIN_TURN_MS=400

# Chunking/generation controls for local backends.
LOCAL_MODEL_CHUNK_MS=1000
LOCAL_MODEL_MAX_NEW_TOKENS=512

# Qwen3-Omni Instruct speaker name. Ignored by MiniCPM-o.
LOCAL_MODEL_QWEN_SPEAKER=Ethan
